// MENGURUTKAN JADWAL BERDASARKAN ID DOSEN DARI ID TERKECIL KE ID TERBESAR
func SelectionSort(h *hari, m *matkul, d *dosen, r *ruangan, n int) {
	var pass, i, idx int
	var tempHari DataHari
	var tempMatkul DataMataKuliah
	var tempDosen DataDosen
	var tempRuangan DataRuangan
	pass = 1
	for pass <= n-1 {
		idx = pass - 1
		i = pass
		for i < n {
			if d[idx].id_dosen > d[i].id_dosen {
				idx = i
			}
			i++
		}
		tempHari = h[pass-1]
		tempMatkul = m[pass-1]
		tempDosen = d[pass-1]
		tempRuangan = r[pass-1]
		h[pass-1] = h[idx]
		m[pass-1] = m[idx]
		d[pass-1] = d[idx]
		r[pass-1] = r[idx]
		h[idx] = tempHari
		m[idx] = tempMatkul
		d[idx] = tempDosen
		r[idx] = tempRuangan
		pass++
	}
}

// MENGURUTKAN BERDASARKAN NAMA HARI DAN WAKTU PERKULIAHAN DIMULAI
func InsertionSort(h *hari, m *matkul, d *dosen, r *ruangan, n int) {
	var pass, i, day int
	var tempHari DataHari
	var tempMatkul DataMataKuliah
	var tempDosen DataDosen
	var tempRuangan DataRuangan
	for pass = 1; pass < n; pass++ {
		i = pass
		tempHari = h[i]
		tempMatkul = m[i]
		tempDosen = d[i]
		tempRuangan = r[i]
		day = HariKeAngka(h[i].Hari)
		for i > 0 {
			if HariKeAngka(h[i-1].Hari) > day || (HariKeAngka(h[i-1].Hari)) == day && tempMatkul.jam_mulai < m[i-1].jam_mulai {
				h[i] = h[i-1]
				m[i] = m[i-1]
				d[i] = d[i-1]
				r[i] = r[i-1]
				i--
			} else {
				break
			}
		}
		h[i] = tempHari
		m[i] = tempMatkul
		d[i] = tempDosen
		r[i] = tempRuangan
	}
}

func SequentialSearch(m matkul, n int, cari string) int {
	for i := 0; i < n; i++ {
		if cari == m[i].nama_matkul {
			return i
		}
	}
	return -1
}

func BinarySearch(d dosen, n, cari int) int {
	var left, right, mid, ketemu int
	left = 0
	right = n - 1
	ketemu = -1
	for left <= right && ketemu == -1 {
		mid = (left + right) / 2
		if cari < d[mid].id_dosen {
			right = mid - 1
		} else if cari > d[mid].id_dosen {
			left = mid + 1
		} else {
			ketemu = mid
		}
	}
	return ketemu
}


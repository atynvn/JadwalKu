func HitungJam(mulai, selesai int) int {
	return selesai - mulai
}

func HariKeAngka(hari string) int {
	switch hari {
	case "Senin":
		return 1
	case "Selasa":
		return 2
	case "Rabu":
		return 3
	case "Kamis":
		return 4
	case "Jumat":
		return 5
	case "Sabtu":
		return 6
	default:
		return 7
	}
}


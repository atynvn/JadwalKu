func TambahkanJadwal(h *hari, m *matkul, d *dosen, r *ruangan, n *int) {
	var inputH DataHari
	var inputM DataMataKuliah
	var inputD DataDosen
	var inputR DataRuangan
	var salah, yes_or_not int
	for {
		fmt.Print("\nMasukkan nama hari : ")
		fmt.Scan(&inputH.Hari)
		fmt.Print("\nMasukkan nama mata kuliah : ")
		fmt.Scan(&inputM.nama_matkul)
		fmt.Print("\nMasukkan jam mulai dan menit mulai : ")
		fmt.Scan(&inputM.jam_mulai, &inputM.menit_mulai)
		fmt.Print("\nMasukkan jam selesai dan menit selesai : ")
		fmt.Scan(&inputM.jam_selesai, &inputM.menit_selesai)
		DosenDosen()
		fmt.Print("\nMasukkan ID dan nama dosen : ")
		fmt.Scan(&inputD.id_dosen, &inputD.nama_dosen)
		Ruangan()
		fmt.Print("\nMasukkan nama ruangan : ")
		fmt.Scan(&inputR.nama_ruangan)

		// CEK PENGINPUTAN USER APAKAH JADWAL BERTABRAKAN TERHADAP JAM PERKULIAHAN DAN RUANGAN PERKULIAHAN
		for i := 0; i < *n; i++ {
			if inputH.Hari == h[i].Hari {
				if inputM.jam_mulai >= m[i].jam_mulai && inputM.jam_mulai <= m[i].jam_selesai || inputM.jam_selesai >= m[i].jam_mulai && inputM.jam_selesai <= m[i].jam_selesai || r[i].nama_ruangan == inputR.nama_ruangan {
					fmt.Println("\nWARNING\nTERDAPAT JADWAL YANG BERTABRAKAN")
					if r[i].nama_ruangan == inputR.nama_ruangan {
						fmt.Printf("\nRuangan %s akan dipakai pada jam %d.%d - %d.%d\n", inputR.nama_ruangan, m[i].jam_mulai, m[i].menit_mulai, m[i].jam_selesai, m[i].menit_selesai)
						fmt.Println("\nIngin tetap tambahkan jadwal? ")
						fmt.Print("\nKetik -1 jika tidak, 0 jika iya : ")
						fmt.Scan(&salah)
					}
					if inputM.jam_mulai >= m[i].jam_mulai && inputM.jam_mulai <= m[i].jam_selesai || inputM.jam_selesai >= m[i].jam_mulai && inputM.jam_selesai <= m[i].jam_selesai {
						fmt.Println("\nTerdapat jadwal yang bertarakan")
						salah = -1
					}
					break
				}
			}
		}

		// PENGINGAT APAKAH USER INGIN MENAMBAH JADWAL ATAU TIDAK
		if salah != -1 {
			fmt.Println("\n------------------------------")
			fmt.Println("Jadwal Berhasil ditambahkan")
			fmt.Println("------------------------------")
			h[*n] = inputH
			m[*n] = inputM
			d[*n] = inputD
			r[*n] = inputR
			(*n)++
			fmt.Println("\n---------- Ingin tambah jadwal lagi ?  ----------")
			fmt.Print("\nKetik 0 jika tidak, 1 jika iya : ")
			fmt.Scan(&yes_or_not)
			if yes_or_not == 0 {
				break
			}
		} else {
			fmt.Println("\n------------------------------")
			fmt.Println("Jadwal Gagal ditambahkan")
			fmt.Println("------------------------------")
			fmt.Println("\n---------- Ingin mencoba tambah jadwal ?  ----------")
			fmt.Print("\nKetik 0 jika tidak, 1 jika iya : ")
			fmt.Scan(&yes_or_not)
			if yes_or_not == 0 {
				break
			}
		}
	}
}

func UbahJadwal(h *hari, m *matkul, d *dosen, r *ruangan, n int) {
	var ubah string
	var temukan, pilihan, f int
	var day DataHari
	var kuliah DataMataKuliah
	var dsn DataDosen
	var ruang DataRuangan
	fmt.Print("\nMasukkan nama mata kuliah yang ingin diubah : ")
	fmt.Scan(&ubah)
	temukan = SequentialSearch(*m, n, ubah)
	if temukan == -1 {
		fmt.Println("\nData yang ingin diubah tidak ditemukan")
	} else {
		fmt.Println("\nMau mengubah bagian:")
		fmt.Println("1. Nama hari perkuliahan")
		fmt.Println("2. Nama mata kuliah")
		fmt.Println("3. Jam perkuliahan")
		fmt.Println("4. ID dan nama dosen")
		fmt.Println("5. Ruangan perkuliahan")
		fmt.Print("\nMasukkan nomor pilihan : ")
		fmt.Scan(&pilihan)
		switch pilihan {
		case 1:
			fmt.Print("\nMasukkan nama hari : ")
			fmt.Scan(&day.Hari)
			h[temukan].Hari = day.Hari
		case 2:
			fmt.Print("\nMasukkan nama mata kuliah : ")
			fmt.Scan(&kuliah.nama_matkul)
			m[temukan].nama_matkul = kuliah.nama_matkul
		case 3:
			fmt.Print("\nMasukkan Jam dan menit mulai kuliah : ")
			fmt.Scan(&kuliah.jam_mulai, &kuliah.menit_mulai)
			fmt.Print("\nMasukkan Jam dan menit selesai kuliah : ")
			fmt.Scan(&kuliah.jam_selesai, &kuliah.menit_selesai)
			for i := 0; i < n; i++ {
				if i != temukan && h[i].Hari == h[temukan].Hari {
					if kuliah.jam_mulai >= m[i].jam_mulai && kuliah.jam_mulai <= m[i].jam_selesai || kuliah.jam_selesai >= m[i].jam_mulai && kuliah.jam_selesai <= m[i].jam_selesai {
						f = -1
						break
					}
				}
			}
			if f == -1 {
				fmt.Println("\nERROR\nTERDAPAT JADWAL YANG BERTABRAKAN")
			} else {
				m[temukan].jam_mulai = kuliah.jam_mulai
				m[temukan].menit_mulai = kuliah.menit_mulai
				m[temukan].jam_selesai = kuliah.jam_selesai
				m[temukan].menit_selesai = kuliah.menit_selesai
			}
		case 4:
			fmt.Print("\nMasukkan ID dan nama dosen : ")
			fmt.Scan(&dsn.id_dosen, &dsn.nama_dosen)
			d[temukan].id_dosen = dsn.id_dosen
			d[temukan].nama_dosen = dsn.nama_dosen
		case 5:
			Ruangan()
			fmt.Print("\nMasukkan nama ruangan perkuliahan : ")
			fmt.Scan(&ruang.nama_ruangan)
			r[temukan].nama_ruangan = ruang.nama_ruangan
		default:
			fmt.Println("\nPilihan tidak diketahui")
			f = -1
		}

		if f == -1 {
			fmt.Println("\n------------------------------")
			fmt.Println("Jadwal Gagal diubah")
			fmt.Println("------------------------------")
		} else {
			fmt.Println("\n------------------------------")
			fmt.Println("Jadwal Berhasil diubah")
			fmt.Println("------------------------------")
		}
	}
}

func HapusJadwal(h *hari, m *matkul, d *dosen, r *ruangan, n *int) {
	var hapus string
	var proses int
	fmt.Print("\nMasukkan nama mata kuliah yang ingin dihapus : ")
	fmt.Scan(&hapus)
	proses = SequentialSearch(*m, *n, hapus)
	if proses == -1 {
		fmt.Println("\nJadwal tidak diketahui")
	} else {
		for i := proses; i < *n; i++ {
			h[i] = h[i+1]
			m[i] = m[i+1]
			d[i] = d[i+1]
			r[i] = r[i+1]
		}
		*n--
		fmt.Println("\n------------------------------")
		fmt.Println("Jadwal berhasil dihapus")
		fmt.Println("------------------------------")
	}
}

